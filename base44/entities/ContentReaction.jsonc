{
  "name": "ContentReaction",
  "type": "object",
  "properties": {
    "user_id": {
      "type": "string",
      "description": "ID of the user who reacted"
    },
    "content_id": {
      "type": "string",
      "description": "ID of the thread, chapter, or comment"
    },
    "content_type": {
      "type": "string",
      "enum": [
        "thread",
        "chapter",
        "forum_comment",
        "post_comment"
      ],
      "description": "Type of content being reacted to"
    }
  },
  "required": [
    "user_id",
    "content_id",
    "content_type"
  ]
}